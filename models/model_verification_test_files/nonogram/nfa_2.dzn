%
% Test: nonogram / NFA #2
%
% Setup: 2x2 grid, alphabet {empty=1, filled=2}.
% Rule (every row and every column): at least one filled cell.
% (Same language as nonogram/dfa_2, but expressed as an NFA with a true
% nondeterministic transition.)
%
% Automaton (NFA, Q=2, S=2; same NFA for every row and every column):
%   q0 = 1, F = {2}
%   q1 = "no filled cells yet"
%   q2 = "filled cell seen (sink, accepting)"
%   Transitions:
%     q1 + empty(1)  -> {1}
%     q1 + filled(2) -> {1, 2}
%     q2 + empty(1)  -> {2}
%     q2 + filled(2) -> {2}
%

width = 2;
height = 2;
mode = 1;
Q = 2;
S = 2;

row_q0 = [1, 1];
row_F  = [{2}, {2}];
row_d_dfa = array3d(1..2, 1..2, 1..2, [
    0, 0,
    0, 0,
    0, 0,
    0, 0,
]);
row_d_nfa = array3d(1..2, 1..2, 1..2, [
    %% row 1
    {1},    {1, 2},
    {2},    {2},
    %% row 2
    {1},    {1, 2},
    {2},    {2},
]);

col_q0 = [1, 1];
col_F  = [{2}, {2}];
col_d_dfa = array3d(1..2, 1..2, 1..2, [
    0, 0,
    0, 0,
    0, 0,
    0, 0,
]);
col_d_nfa = array3d(1..2, 1..2, 1..2, [
    %% col 1
    {1},    {1, 2},
    {2},    {2},
    %% col 2
    {1},    {1, 2},
    {2},    {2},
]);
