%
% Test: shift_scheduling / NFA #1
%
% Language: sequences of length 4 over {Day=1, Night=2} containing the
%           substring "Night Day" somewhere.
%
% Automaton (NFA, Q=3, S=2):
%   q0 = 1, F = {3}
%   q1 = "no match yet"
%   q2 = "just saw Night, looking for Day"
%   q3 = "matched (sink, accepting)"
%   Transitions (sets; empty set = dead branch):
%     q1 + Day(1)   -> {1}
%     q1 + Night(2) -> {1, 2}
%     q2 + Day(1)   -> {3}
%     q2 + Night(2) -> {2}
%     q3 + Day(1)   -> {3}
%     q3 + Night(2) -> {3}
%

sequence_length = 4;
mode = 1;
Q = 3;
S = 2;
q0 = 1;
F = {3};
d_dfa = array2d(1..3, 1..2, [
    0, 0,
    0, 0,
    0, 0,
]);
d_nfa = array2d(1..3, 1..2, [
    {1},    {1, 2},
    {3},    {2},
    {3},    {3},
]);
