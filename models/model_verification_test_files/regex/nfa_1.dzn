%
% Test: regex / NFA #1
%
% Language: strings of length 3 over {a=1, b=2} containing the substring
% "ab" somewhere.  Equivalent regex: (a|b)* a b (a|b)*
%
% Automaton (NFA, Q=3, S=2; the textbook Thompson-style NFA for "contains
% ab"):
%   q0 = 1, F = {3}
%   q1 = "looking for the start of an 'ab' match"
%   q2 = "saw an 'a', looking for a 'b'"
%   q3 = "matched (sink, accepting)"
%   Transitions (sets):
%     q1 + a(1) -> {1, 2}
%     q1 + b(2) -> {1}
%     q2 + a(1) -> {2}
%     q2 + b(2) -> {3}
%     q3 + a(1) -> {3}
%     q3 + b(2) -> {3}
%

var_count = 3;
mode = 1;
Q = 3;
S = 2;
q0 = 1;
F = {3};
d_dfa = array2d(1..3, 1..2, [
    0, 0,
    0, 0,
    0, 0,
]);
d_nfa = array2d(1..3, 1..2, [
    {1, 2},   {1},
    {2},      {3},
    {3},      {3},
]);
