%
% Test: regex / DFA #1
%
% Language: strings of length 4 over {a=1, b=2} that end with the substring
% "ab".  Equivalent regex: (a|b)*ab
%
% Automaton (DFA, Q=3, S=2):
%   q0 = 1, F = {3}
%   q1 = "neither just-saw-a nor matched"
%   q2 = "just saw a"
%   q3 = "just saw a then b (accepting)"
%   Transitions:
%     q1 + a(1) -> q2
%     q1 + b(2) -> q1
%     q2 + a(1) -> q2
%     q2 + b(2) -> q3
%     q3 + a(1) -> q2
%     q3 + b(2) -> q1
%

var_count = 4;
mode = 0;
Q = 3;
S = 2;
q0 = 1;
F = {3};
d_dfa = array2d(1..3, 1..2, [
    2, 1,
    2, 3,
    2, 1,
]);
d_nfa = array2d(1..3, 1..2, [
    {}, {},
    {}, {},
    {}, {},
]);
