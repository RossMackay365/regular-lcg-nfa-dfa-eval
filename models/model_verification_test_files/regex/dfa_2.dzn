%
% Test: regex / DFA #2
%
% Language: strings of length 3 over {a=1, b=2} matching  a* b*  (any
% number of a's, then any number of b's).
%
% Automaton (DFA, Q=2, S=2):
%   q0 = 1, F = {1, 2}
%   q1 = "still in the a* phase (accepts the empty suffix here)"
%   q2 = "in the b* phase"
%   Transitions:
%     q1 + a(1) -> q1
%     q1 + b(2) -> q2
%     q2 + a(1) -> 0   (cannot return to a's)
%     q2 + b(2) -> q2
%

var_count = 3;
mode = 0;
Q = 2;
S = 2;
q0 = 1;
F = {1, 2};
d_dfa = array2d(1..2, 1..2, [
    1, 2,
    0, 2,
]);
d_nfa = array2d(1..2, 1..2, [
    {}, {},
    {}, {},
]);
