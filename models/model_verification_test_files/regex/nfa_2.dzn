%
% Test: regex / NFA #2
%
% Language: strings of length 3 over {a=1, b=2} that end with 'a'.
% Equivalent regex: (a|b)* a
%
% Automaton (NFA, Q=2, S=2):
%   q0 = 1, F = {2}
%   q1 = "haven't committed to ending"
%   q2 = "the previous symbol was 'a' and is the final symbol"
%   Transitions:
%     q1 + a(1) -> {1, 2}
%     q1 + b(2) -> {1}
%     q2 + a(1) -> {}
%     q2 + b(2) -> {}
%

var_count = 3;
mode = 1;
Q = 2;
S = 2;
q0 = 1;
F = {2};
d_dfa = array2d(1..2, 1..2, [
    0, 0,
    0, 0,
]);
d_nfa = array2d(1..2, 1..2, [
    {1, 2},   {1},
    {},       {},
]);
