%
% Test: pentominoes / NFA
%
% Setup: 5x5 board, tiles=5 (marker=6, S=6), n_expressions=5.
%

size = 5;
tiles = 5;
mode = 1; 
n_expressions = 5;
Q = 7;
S = 6;

q0 = [1, 1, 1, 1, 1];
F  = [{6}, {6}, {6}, {6}, {6}];

d_dfa = array3d(1..5, 1..7, 1..6, [ 0 | e in 1..5, q in 1..7, s in 1..6 ]);

d_nfa = array3d(1..5, 1..7, 1..6, [
    %% Expression 1: NFA Counter for Tile 1 (A)
    % 1(A)      2(B)   3(C)   4(D)   5(E)   6(Marker)
    {2},        {1},   {1},   {1},   {1},   {1}, % State 1
    {3},        {2},   {2},   {2},   {2},   {2}, % State 2
    {4},        {3},   {3},   {3},   {3},   {3}, % State 3
    {5},        {4},   {4},   {4},   {4},   {4}, % State 4
    {6},        {5},   {5},   {5},   {5},   {5}, % State 5
    {},         {6},   {6},   {6},   {6},   {6}, % State 6 (Accepting)
    {},         {},    {},    {},    {},    {},  % State 7 (Fail Sink)

    %% Expression 2: NFA Counter for Tile 2 (B)
    {1},        {2},   {1},   {1},   {1},   {1},
    {2},        {3},   {2},   {2},   {2},   {2},
    {3},        {4},   {3},   {3},   {3},   {3},
    {4},        {5},   {4},   {4},   {4},   {4},
    {5},        {6},   {5},   {5},   {5},   {5},
    {6},        {},    {6},   {6},   {6},   {6},
    {},         {},    {},    {},    {},    {},

    %% Expression 3: NFA Counter for Tile 3 (C)
    {1},        {1},   {2},   {1},   {1},   {1},
    {2},        {2},   {3},   {2},   {2},   {2},
    {3},        {3},   {4},   {3},   {3},   {3},
    {4},        {4},   {5},   {4},   {4},   {4},
    {5},        {5},   {6},   {5},   {5},   {5},
    {6},        {6},   {},    {6},   {6},   {6},
    {},         {},    {},    {},    {},    {},

    %% Expression 4: NFA Counter for Tile 4 (D)
    {1},        {1},   {1},   {2},   {1},   {1},
    {2},        {2},   {2},   {3},   {2},   {2},
    {3},        {3},   {3},   {4},   {3},   {3},
    {4},        {4},   {4},   {5},   {4},   {4},
    {5},        {5},   {5},   {6},   {5},   {5},
    {6},        {6},   {6},   {},    {6},   {6},
    {},         {},    {},    {},    {},    {},

    %% Expression 5: NFA Counter for Tile 5 (E)
    {1},        {1},   {1},   {1},   {2},   {1},
    {2},        {2},   {2},   {2},   {3},   {2},
    {3},        {3},   {3},   {3},   {4},   {3},
    {4},        {4},   {4},   {4},   {5},   {4},
    {5},        {5},   {5},   {5},   {6},   {5},
    {6},        {6},   {6},   {6},   {},    {6},
    {},         {},    {},    {},    {},    {}
]);